@startuml
title Diagrama de Clases - Registro de Notas - SYS COLEGIO EMANUEL

skinparam backgroundColor #F5F0FA
skinparam classBackgroundColor #E8D7F5
skinparam classBorderColor #8A2BE2
skinparam enumBackgroundColor #E8D7F5
skinparam enumBorderColor #8A2BE2
skinparam arrowColor #9400D3

'====================================
' ENUMS
'====================================

enum TipoEvaluación {
    EVALUACION_CONTINUA
    EXAMEN_PARCIAL
    EXAMEN_FINAL
    PROYECTO
}

enum Bimestre {
    PRIMER_BIMESTRE
    SEGUNDO_BIMESTRE
    TERCER_BIMESTRE
    CUARTO_BIMESTRE
}

'=================================
' CONTROLADORES Y SERVICIOS (BACKEND)
'=================================

class NotaController {
    + obtenerMatrizEstudiantes(grado: String, seccion: String, cursoId: int, bimestre: Bimestre): ResponseEntity
    + registrarCalificaciones(request: RegistrarNotasRequest): ResponseEntity
}

class NotaService {
    - notaRepository: NotaRepository
    - alumnoRepository: AlumnoRepository
    - auditoriaService: AuditoriaService

    + listarAlumnosYNotas(grado: String, seccion: String, cursoId: int, bimestre: Bimestre): List<MatrizNotasDTO>
    + procesarRegistroNotas(request: RegistrarNotasRequest): void
    + validarIntegridadRangos(calificacion: double): boolean
    + calcularPromediosAutomaticos(notas: List<Double>): double
}

NotaController --> NotaService : invoca

'=====================================
' ENTIDADES / MODELOS DE PERSISTENCIA
'=====================================

class Docente {
    - idDocente: int
    - codigoEmpleado: String
    - nombres: String
    - apellidos: String
    - especialidad: String
    - estado: boolean
}

class Alumno {
    - idAlumno: int
    - codigoEstudiante: String
    - nombres: String
    - apellidos: String
    - grado: String
    - seccion: String
    - estado: boolean
}

class Curso {
    - idCurso: int
    - nombre: String
    - creditos: int
    - estado: boolean
}

class Nota {
    - idNota: int
    - valorNota: double
    - tipo: TipoEvaluación
    - fechaRegistro: DateTime
    
    + actualizarCalificacion(nuevoValor: double): void
}

class RegistroPromedio {
    - idPromedio: int
    - bimestre: Bimestre
    - promedioFinal: double
    - fechaConsolidacion: DateTime
    - aprobado: boolean
}

'=========================================
' RELACIONES DE DOMINIO ACADÉMICO
'=========================================

Docente "1" --> "*" Curso : dicta
Curso "1" --> "*" Nota : contiene
Alumno "1" --> "*" Nota : obtiene
Alumno "1" --> "*" RegistroPromedio : acumula
Bimestre "1" <-- RegistroPromedio : pertenece

NotaService ..> Nota : gestiona
NotaService ..> RegistroPromedio : calcula

'=========================================
' AUDITORÍA (SEGURIDAD INMUTABLE)
'=========================================

class AuditoriaNotas {
    - idAuditoria: int
    - idDocente: int
    - accion: String
    - detallesCambio: String
    - fechaHora: DateTime
    - ipOrigen: String

    + registrarEventoInmutable(): void
}

NotaService --> AuditoriaNotas : genera de forma automática

@enduml