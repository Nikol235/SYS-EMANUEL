@startuml
left to right direction
!theme plain

skinparam backgroundColor #FFF0F5
skinparam packageBackgroundColor #FFC0CB
skinparam packageBorderColor #C71585

skinparam usecase {
    BackgroundColor #FFD1DC
    BorderColor #C71585
    ArrowColor #C71585
}

skinparam actor {
    BorderColor #C71585
    BackgroundColor #FFB6C1
}

actor "Docente" as docente
actor "Padre" as padre

package "SISTEMA SYS-COLEGIO-EMANUEL" {

    usecase "Registrar Asistencia" as asistencia
    usecase "Escanear QR Alumno" as qr
    usecase "Registrar Estado\n(Presente/Tarde/Falta)" as estado
    usecase "Enviar Notificación Push" as push
    usecase "Enviar Aviso WhatsApp" as whatsapp
    usecase "Registrar Auditoría" as auditoria
}

docente --> asistencia
padre --> push
padre --> whatsapp

asistencia ..> qr : <<include>>
asistencia ..> estado : <<include>>
asistencia ..> push : <<include>>
asistencia ..> whatsapp : <<include>>
asistencia ..> auditoria : <<include>>

@enduml