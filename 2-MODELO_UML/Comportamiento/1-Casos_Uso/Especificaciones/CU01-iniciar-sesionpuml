@startuml
left to right direction
!theme plain

skinparam backgroundColor #FFF0F5
skinparam packageBackgroundColor #FFC0CB
skinparam packageBorderColor #C71585

skinparam usecase {
    BackgroundColor #FFD1DC
    BorderColor #C71585
    ArrowColor #C71585
}

skinparam actor {
    BorderColor #C71585
    BackgroundColor #FFB6C1
}

actor "Usuario" as usuario

package "SISTEMA SYS-COLEGIO-EMANUEL" {

    usecase "Iniciar Sesión" as login
    usecase "Autenticar Usuario" as auth
    usecase "Generar Token JWT" as jwt
    usecase "Validar Rol" as rol
    usecase "Redirigir según Rol" as redireccion
}

usuario --> login

login ..> auth : <<include>>
login ..> jwt : <<include>>
login ..> rol : <<include>>
login ..> redireccion : <<include>>

@enduml