@startuml
left to right direction
!theme plain

skinparam backgroundColor #FFF8EE
skinparam packageBackgroundColor #FAEEDA
skinparam packageBorderColor #854F0B

skinparam usecase {
    BackgroundColor #FFE9B0
    BorderColor #854F0B
    ArrowColor #854F0B
}

skinparam actor {
    BorderColor #854F0B
    BackgroundColor #F5C97F
}

title CU04 - Enviar Comunicado / Aviso\nSistema: SYS-COLEGIO-EMANUEL

actor "Docente / Admin" as docente
actor "Padre"           as padre

package "SISTEMA SYS-COLEGIO-EMANUEL" {

    usecase "Publicar Comunicado" as comunicado
    usecase "Completar Formulario\n(Título, Mensaje,\nDestinatarios)" as formulario
    usecase "Adjuntar Imagen\no Archivo (Opc.)" as adjunto
    usecase "Subir Archivo a\nCloudflare R2 (multer)" as upload
    usecase "Guardar en BD\nCommunications" as bd
    usecase "Enviar Notificación\nPush FCM" as push
    usecase "Enviar Aviso\nWhatsApp (Baileys)" as whatsapp
}

docente --> comunicado
padre   --> push
padre   --> whatsapp

comunicado ..> formulario : <<include>>
comunicado ..> adjunto    : <<extend>>
adjunto    ..> upload     : <<include>>
comunicado ..> bd         : <<include>>
comunicado ..> push       : <<include>>
comunicado ..> whatsapp   : <<extend>>

note right of upload
  Archivo almacenado en
  Cloudflare R2 vía multer
end note

@enduml
