@startuml
skinparam backgroundColor #FFF0F5
skinparam participantBackgroundColor #FFD1DC
skinparam participantBorderColor #C71585
skinparam actorBackgroundColor #FFB6C1
skinparam actorBorderColor #C71585
skinparam arrowColor #C71585
skinparam lifeLineBorderColor #C71585

actor "Director/Secretaria" as user
participant "App Web" as app
participant "ComunicadoController" as controller
participant "ComunicadoService" as service
participant "BaseDatos" as db
participant "PushNotificaciones" as push

user -> app : Redacta comunicado y elige destinatarios
activate app
app -> controller : enviarComunicado(asunto, cuerpo, tipoDestinatario)
activate controller
controller -> service : procesarComunicado(asunto, cuerpo, tipoDestinatario)
activate service
service -> service : validarDatos()
service -> db : obtenerDestinatarios(tipoDestinatario)
activate db
db --> service : Lista de destinatarios
deactivate db
service -> db : guardarComunicado(comunicado)
activate db
db --> service : confirmacionGuardado
deactivate db
service -> push : enviarNotificaciones(destinatarios, asunto)
activate push
push --> service : resultado(enviados, fallidos)
deactivate push
service -> db : registrarHistorial(comunicado, resultado)
activate db
db --> service : confirmacion
deactivate db
service --> controller : retornaResultado(estado)
deactivate service
controller --> app : mostrarConfirmacion(estado)
deactivate controller
app --> user : Muestra "Comunicado enviado a 120 destinatarios"
deactivate app

@enduml