@startuml
skinparam backgroundColor #FFF0F5
skinparam participantBackgroundColor #FFD1DC
skinparam participantBorderColor #C71585
skinparam actorBackgroundColor #FFB6C1
skinparam actorBorderColor #C71585
skinparam arrowColor #C71585
skinparam lifeLineBorderColor #C71585

actor "Padre" as padre
participant "Interfaz Web" as ui
participant "ControladorAcademico" as controller
participant "ServicioAcademico" as service
participant "BaseDatos" as db

padre -> ui : Hace click en "Ver Notas"
activate ui
ui -> controller : solicitarNotas(idAlumno)
activate controller
controller -> service : buscarNotas(idAlumno)
activate service
service -> db : SELECT * FROM notas WHERE id = idAlumno
activate db
db --> service : Retorna lista de notas
deactivate db
service --> controller : devuelveNotas(notas)
deactivate service
controller --> ui : mostrarNotas(notas)
deactivate controller
ui --> padre : Muestra tabla de calificaciones
deactivate ui

@enduml