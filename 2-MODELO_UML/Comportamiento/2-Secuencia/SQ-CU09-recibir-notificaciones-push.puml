@startuml
skinparam backgroundColor #FFF0F5
skinparam participantBackgroundColor #FFD1DC
skinparam participantBorderColor #C71585
skinparam actorBackgroundColor #FFB6C1
skinparam actorBorderColor #C71585
skinparam arrowColor #C71585
skinparam lifeLineBorderColor #C71585

participant "MicroservicioOrigen" as origen
participant "ComunicadosService" as service
participant "BaseDatos" as db
participant "FirebaseFCM" as fcm
actor "Dispositivo Usuario" as dispositivo

origen -> service : notificar(tipoEvento, idDestinatarios, mensaje)
activate service
service -> db : obtenerTokensFCM(idDestinatarios)
activate db
db --> service : Lista de tokens activos
deactivate db

loop Para cada token activo
    service -> fcm : enviarPush(token, titulo, cuerpo)
    activate fcm
    fcm --> service : resultado(entregado/fallido)
    deactivate fcm
    service -> db : actualizarEstadoNotificacion(token, resultado)
    activate db
    db --> service : confirmacion
    deactivate db
end

service -> db : registrarHistorial(evento, totales)
activate db
db --> service : historial guardado
deactivate db

fcm -> dispositivo : Notificacion push recibida
activate dispositivo
dispositivo --> fcm : ACK
deactivate dispositivo

service --> origen : resumen(enviadas, entregadas, fallidas)
deactivate service

@enduml