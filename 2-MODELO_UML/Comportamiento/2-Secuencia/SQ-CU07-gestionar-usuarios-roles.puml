@startuml
skinparam backgroundColor #FFF0F5
skinparam participantBackgroundColor #FFD1DC
skinparam participantBorderColor #C71585
skinparam actorBackgroundColor #FFB6C1
skinparam actorBorderColor #C71585
skinparam arrowColor #C71585
skinparam lifeLineBorderColor #C71585

actor "Director" as dir
participant "App Web" as app
participant "UsuarioController" as controller
participant "UsuarioService" as service
participant "BaseDatos" as db
participant "AuditoriaService" as auditoria

dir -> app : Ingresa datos del nuevo usuario y rol
activate app
app -> controller : crearUsuario(datos, rol)
activate controller
controller -> service : registrarUsuario(datos, rol)
activate service
service -> service : validarDatos()
service -> db : verificarUsernameDisponible(username)
activate db
db --> service : disponible: true
deactivate db
service -> service : hashPassword(passwordTemporal)
service -> db : guardarUsuario(usuario)
activate db
db --> service : usuarioGuardado
deactivate db
service -> auditoria : registrarAccion(CREAR, username, director)
activate auditoria
auditoria --> service : registrado
deactivate auditoria
service --> controller : retornaUsuario(usuario)
deactivate service
controller --> app : mostrarConfirmacion(usuario)
deactivate controller
app --> dir : Muestra "Usuario creado exitosamente"
deactivate app

@enduml